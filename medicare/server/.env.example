# ---- MediCare server environment ----
PORT=5000
NODE_ENV=development

# MongoDB (local or Atlas connection string)
MONGO_URI=mongodb://localhost:27017/medicare

# Auth
JWT_SECRET=change_me_to_a_long_random_string
JWT_EXPIRES_IN=7d

# Frontend origin for CORS
CLIENT_URL=http://localhost:3000

# ---- Third-party APIs ----
# RxNav (NIH) and openFDA are KEYLESS — no key required.
# Base URLs are configurable in case the public endpoints ever change.
RXNAV_BASE_URL=https://rxnav.nlm.nih.gov/REST
OPENFDA_BASE_URL=https://api.fda.gov/drug

# Optional default seed admin (used by `npm run seed`)
SEED_ADMIN_EMAIL=admin@medicare.dev
SEED_ADMIN_PASSWORD=Admin123!
SEED_PATIENT_EMAIL=patient@medicare.dev
SEED_PATIENT_PASSWORD=Patient123!
